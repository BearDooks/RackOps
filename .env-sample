# --- Database Configuration ---
# Example for SQLite (Default):
DATABASE_URL=sqlite:///./dcim.db
# Example for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/rackops

# --- Security Configuration ---
# MANDATORY: A long, random string for JWT signing
SECRET_KEY=change-me-to-a-secure-random-string

# --- App Settings ---
# Restrictive by default. Use comma-separated list of origins.
ALLOWED_ORIGINS=http://localhost:8000
# Set to True/False to force seeding behavior, or 'auto' (default) to seed if DB is empty and in LOCAL mode.
SEED_DEFAULT_ADMIN=auto

# --- Azure AD Auth Configuration (Optional) ---
# Set to AZURE to enable Azure AD authentication
AUTH_MODE=LOCAL
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
# Provide IDs for mapped groups
AZURE_OPERATORS_GROUP_ID=
AZURE_VIEWERS_GROUP_ID=
